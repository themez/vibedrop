{
  "name": "@vibedrop/mcp",
  "version": "0.1.3",
  "description": "MCP server for deploying static sites to VibeDrop.",
  "license": "MIT",
  "homepage": "https://vibedrop.cc",
  "repository": {
    "type": "git",
    "url": "https://github.com/themez/vibedrop.git",
    "directory": "packages/mcp"
  },
  "keywords": ["mcp", "model-context-protocol", "claude", "cursor", "static-site", "deploy", "vibedrop"],
  "publishConfig": {
